<header class="ma-header">
  <div class="ma-container">
    <div class="ma-inner">
      <a href="<%= pathPrefix %>index.html" class="ma-header__logo">
        <img src="/images/logo.png" alt="Metaassets" />
      </a>

      <!-- 大版導覽列 -->
      <nav
        class="ma-action-group ma-action-group--desktop"
        aria-label="Header actions"
      >
        <!-- =========================
             大版右上角：登入前 / 登入後 二擇一
             PHP 工程師依登入狀態輸出對應連結
             ========================= -->

        <!-- 登入前顯示：登入/設定 -->

        <a href="<%= pathPrefix %>login-setting.html">登入/設定</a>

        <!-- 登入後顯示：查看鏈證 -->
        <!--

        <a href="<%= pathPrefix %>user/assets.html">查看鏈證</a>
-->
        <!-- ========================= -->

        <button
          id="lang-toggle-pc"
          class="ma-icon-btn"
          type="button"
          aria-label="Language"
        >
          <img src="/images/icon_lang.png" alt="" />
        </button>
      </nav>

      <!-- 小版導覽列 -->
      <div class="ma-action-group ma-action-group--mobile">
        <button
          id="menu-toggle"
          class="ma-icon-btn"
          type="button"
          aria-label="Menu"
          aria-controls="mobile-drawer"
          aria-expanded="false"
        >
          <img src="/images/icon_bar.png" alt="" />
        </button>

        <button
          id="lang-toggle-mobile"
          class="ma-icon-btn"
          type="button"
          aria-label="Language"
        >
          <img src="/images/icon_lang.png" alt="" />
        </button>
      </div>
    </div>

    <!-- 桌機主導覽 -->
    <nav class="ma-navbar" aria-label="Primary">
      <div class="ma-navbar__links">
        <a target="_blank" href="<%= pathPrefix %>act.html" class="is-active">
          ACT 鏈證
        </a>

        <a href="<%= pathPrefix %>index.html#ma-assets">藝術資產</a>

        <a href="<%= pathPrefix %>index.html#ma-collect">收藏推薦</a>

        <a href="<%= pathPrefix %>search-assets.html">鏈證搜尋</a>

        <a href="<%= pathPrefix %>index.html#ma-service__about">
          關於 Metaassets
        </a>
      </div>
    </nav>
  </div>
</header>

<!-- 導覽列選單 -->
<div id="menu-overlay" class="ma-overlay"></div>

<div
  id="mobile-drawer"
  class="ma-drawer"
  tabindex="-1"
  aria-hidden="true"
  hidden
>
  <div class="ma-drawer__panel">
    <!-- 主選單內容 -->
    <div id="menu-content" class="ma-mobile-menu ma-mobile-menu--nav">
      <!-- 上方頁籤 -->
      <div
        class="ma-mobile-menu__tabs"
        role="tablist"
        aria-label="Mobile menu tabs"
      >
        <button
          type="button"
          class="ma-mobile-menu__tab is-active"
          data-menu-tab="explore"
          role="tab"
          aria-selected="true"
        >
          探　索
        </button>

        <!-- 會員頁籤：登入後才顯示 -->
        <button
          type="button"
          class="ma-mobile-menu__tab"
          data-menu-tab="member"
          role="tab"
          aria-selected="false"
        >
          波波雞
        </button>
      </div>

      <!-- 探索選單 -->
      <div
        class="ma-mobile-menu__panel is-active"
        data-menu-panel="explore"
        role="tabpanel"
      >
        <!-- 當前頁在連結上樣式: class="is-active"-->
        <div class="ma-mobile-menu__links">
          <a target="_blank" href="<%= pathPrefix %>act.html" class="is-active"
            >ACT 鏈證</a
          >

          <a href="<%= pathPrefix %>index.html#ma-assets"> 藝術資產 </a>

          <a href="<%= pathPrefix %>index.html#ma-collect">收藏推薦</a>

          <a href="<%= pathPrefix %>search-assets.html">鏈證搜尋</a>

          <a href="<%= pathPrefix %>index.html#ma-service__about">
            關於 Metaassets
          </a>
        </div>
      </div>

      <!-- 會員選單：登入後才看的到 -->
      <div
        class="ma-mobile-menu__panel"
        data-menu-panel="member"
        role="tabpanel"
        hidden
      >
        <!-- 當前頁在連結上樣式: class="is-active"-->
        <div class="ma-mobile-menu__links">
          <a href="<%= pathPrefix %>user/assets.html" class="is-active"
            >藝術資產</a
          >

          <a href="<%= pathPrefix %>user/transaction-records.html">
            交易鏈證紀錄
          </a>

          <a href="<%= pathPrefix %>user/transaction-assigned.html">
            指定給我的交易
          </a>

          <a href="<%= pathPrefix %>user/login-change.html">個人錢包設定</a>

          <a href="<%= pathPrefix %>line.html">問題詢問</a>
        </div>
      </div>

      <!-- 底部操作區 -->
      <div class="ma-mobile-menu__footer">
        <!-- =========================
             小版底部按鈕：登入前 / 登入後 二擇一
             PHP 工程師依登入狀態輸出對應區塊
             ========================= -->

        <!-- 登入前顯示 -->
        <!--
        <a
          href="<%= pathPrefix %>login.html"
          class="ma-mobile-menu__footer-btn"
        >
          登入
        </a>

        <a
          href="<%= pathPrefix %>login-setting.html"
          class="ma-mobile-menu__footer-btn ma-mobile-menu__footer-btn--dark is-active"
        >
          設定
        </a>
        -->

        <!-- 登入後顯示 -->
        <a href="#" class="ma-mobile-menu__footer-btn">查看鏈證</a>

        <a
          href="<%= pathPrefix %>login-setting.html"
          class="ma-mobile-menu__footer-btn ma-mobile-menu__footer-btn--dark is-active"
        >
          登入/設定
        </a>

        <!-- ========================= -->
      </div>
    </div>

    <!-- 語言選單 -->
    <div
      id="lang-content"
      class="ma-mobile-menu ma-mobile-menu--lang is-hidden"
    >
      <div class="ma-mobile-menu__links ma-mobile-menu__links--lang">
        <a href="#!" class="is-active">中 文</a>
        <a href="#!">English</a>
        <a href="#!">日本語</a>
        <a href="#!">한국어</a>
        <a href="#!">Español</a>
        <a href="#!">Français</a>
        <a href="#!">Deutsch</a>
      </div>
    </div>
  </div>
</div>
